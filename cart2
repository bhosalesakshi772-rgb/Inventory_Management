 Q2) Write a script that checks disk usage for all partitions and warns the user if the usage exceeds 80%.
  #!/bin/bash
THRESHOLD=80 [cite: 225]

# List disk usage, filter headers, and extract usage % and partition name [cite: 226, 227, 228]
df -H | grep -v '^Filesystem\|tmpfs\|cdrom' | awk '{print $5 " " $1}' | while read output;
do
  usage=$(echo $output | awk '{print $1}' | cut -d'%' -f1) [cite: 230]
  partition=$(echo $output | awk '{print $2}') [cite: 231]

  # Check if the usage exceeds the threshold [cite: 232]
  if [ $usage -ge $THRESHOLD ]; then
    echo "Warning: Disk usage on $partition is at ${usage}%" [cite: 232]
  fi
done

